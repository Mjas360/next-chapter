{
  "name": "moonieapp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "ENVFILE=.env.development react-native run-android",
    "ios": "ENVFILE=.env.development node scripts/ios-name.js",
    "lint": "eslint .",
    "start": "react-native start --reset-cache",
    "clean:ios": "cd ios && rm -rf Pods && rm -rf Podfile.lock && rm -rf moonieapp.xcworkspace && pod install && cd ..",
    "clean:android": "cd android && rm -rf .gradle && ./gradlew clean --warning-mode all && cd ..",
    "generate:locale-index": "node scripts/i18n-builder/generate-locale-index.js",
    "i18n:builder": "node scripts/i18n-builder/i18n-namespaced-builder.js && npm run generate:locale-index",
    "json:to:csv": "node scripts/jsonTocsv.js",
    "csv:to:json": "node scripts/csvTojson.js",
    "test": "jest"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native/new-app-screen": "0.84.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.100.1",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "google-libphonenumber": "^3.2.44",
    "i": "^0.3.7",
    "i18next": "^26.0.7",
    "npm": "^11.13.0",
    "phosphor-react-native": "^3.0.4",
    "react": "19.2.3",
    "react-hook-form": "^7.73.1",
    "react-i18next": "^17.0.4",
    "react-native": "^0.84",
    "react-native-bootsplash": "^7.3.1",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-inappbrowser-reborn": "^3.7.1",
    "react-native-keychain": "^10.0.0",
    "react-native-localize": "^3.7.0",
    "react-native-paper": "^5.15.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@bam.tech/react-native-make": "^3.0.3",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/eslint-config": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@react-native/typescript-config": "0.84.0",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
